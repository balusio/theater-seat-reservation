generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EventStatus {
  SCHEDULED
  OPEN
  CLOSED
}

enum SeatStatus {
  AVAILABLE
  HELD
  BOOKED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REJECTED
}

model Theater {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  address       String?
  totalCapacity Int
  createdAt     DateTime  @default(now())
  sections      Section[]
  events        Event[]
}

model Section {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  theaterId   String  @db.Uuid
  name        String
  rows        Int
  seatsPerRow Int
  theater     Theater @relation(fields: [theaterId], references: [id])
  seats       Seat[]

  @@unique([theaterId, name])
}

model Seat {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionId  String     @db.Uuid
  row        String
  number     Int
  label      String?
  section    Section    @relation(fields: [sectionId], references: [id])
  eventSeats EventSeat[]

  @@unique([sectionId, row, number])
}

model Event {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  theaterId    String        @db.Uuid
  title        String
  startsAt     DateTime
  endsAt       DateTime?
  status       EventStatus   @default(SCHEDULED)
  createdAt    DateTime      @default(now())
  theater      Theater       @relation(fields: [theaterId], references: [id])
  eventSeats   EventSeat[]
  reservations Reservation[]

  @@index([startsAt])
  @@index([theaterId])
}

model EventSeat {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId          String            @db.Uuid
  seatId           String            @db.Uuid
  status           SeatStatus        @default(AVAILABLE)
  price            Decimal           @db.Decimal(10, 2)
  updatedAt        DateTime          @updatedAt
  event            Event             @relation(fields: [eventId], references: [id])
  seat             Seat              @relation(fields: [seatId], references: [id])
  reservationSeats ReservationSeat[]

  @@unique([eventId, seatId])
  @@index([eventId, status])
}

model Reservation {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  idempotencyKey     String?           @unique
  eventId            String            @db.Uuid
  status             ReservationStatus @default(PENDING)
  expiresAt          DateTime?
  confirmedAt        DateTime?
  cancelledAt        DateTime?
  rejectedAt         DateTime?
  rejectionReason    String?
  cancellationReason String?
  metadata           Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  event              Event             @relation(fields: [eventId], references: [id])
  reservationSeats   ReservationSeat[]
  auditLogs          AuditLog[]

  @@index([status, expiresAt])
  @@index([eventId])
}

model ReservationSeat {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId String      @db.Uuid
  eventSeatId   String      @db.Uuid
  isActive      Boolean     @default(true)
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  eventSeat     EventSeat   @relation(fields: [eventSeatId], references: [id])

  @@unique([reservationId, eventSeatId])
  @@index([reservationId])
  @@index([eventSeatId, isActive])
}

model AuditLog {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId  String?      @db.Uuid
  entityType     String
  entityId       String       @db.Uuid
  action         String
  previousStatus String?
  newStatus      String?
  triggeredBy    String
  metadata       Json?
  timestamp      DateTime     @default(now())
  reservation    Reservation? @relation(fields: [reservationId], references: [id])

  @@index([reservationId])
  @@index([timestamp])
  @@index([entityType, action])
}
